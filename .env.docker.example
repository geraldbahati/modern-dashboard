# Docker Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Database Configuration
# =============================================================================

# Auth Database (Neon PostgreSQL)
# Used by better-auth for user sessions, accounts, etc.
AUTH_DATABASE_URL=postgresql://user:password@host:5432/auth_db

# App Database (Neon PostgreSQL)
# Used for application data (projects, tasks, etc.)
DATABASE_URL=postgresql://user:password@host:5432/app_db

# =============================================================================
# Authentication Configuration
# =============================================================================

# Auth Secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
# MUST be the same for both web and server
BETTER_AUTH_SECRET=your-super-secret-key-min-32-chars-here

# Server-side auth URL (where the Hono server is running)
BETTER_AUTH_URL=http://localhost:3001

# Client-side auth URL (public facing, embedded in Next.js build)
NEXT_PUBLIC_AUTH_URL=http://localhost:3001/api/auth

# =============================================================================
# Application URLs
# =============================================================================

# Frontend URL (used in emails, redirects, etc.)
FRONTEND_URL=http://localhost:3000

# API URL (for server-side communication in Docker)
# In production Docker, this should be the internal service URL
# For local development, use http://localhost:3001
# API_URL=http://server:3001  # Uncomment for Docker production

# Public API URL (for client-side browser requests)
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# External Services
# =============================================================================

# Resend API Key (for sending emails)
# Get from: https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Arcjet API Key (for rate limiting and security)
# Get from: https://arcjet.com
ARCJET_KEY=your_arcjet_key_here

# =============================================================================
# Optional OAuth Providers
# =============================================================================

# Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# Production Overrides (for Docker deployment)
# =============================================================================

# Node Environment
NODE_ENV=production

# Disable Next.js telemetry (optional)
# NEXT_TELEMETRY_DISABLED=1
